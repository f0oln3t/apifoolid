rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Profil user: siapa aja bisa baca, cuma pemilik akun yang bisa nulis punya sendiri
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Daftar API: publik bisa baca semua.
    // Create: harus login & authorUid harus sama dengan uid yang login.
    // Update: pemilik boleh edit apa aja, ATAU siapa aja yang login boleh ubah field "likes" doang (buat fitur like).
    // Delete: cuma pemilik.
    match /apis/{apiId} {
      allow read: if true;

      allow create: if request.auth != null
                    && request.resource.data.authorUid == request.auth.uid
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.title.size() < 120
                    && request.resource.data.endpoint is string
                    && request.resource.data.endpoint.size() > 0;

      allow update: if request.auth != null && (
                      resource.data.authorUid == request.auth.uid ||
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'updatedAt'])
                    );

      allow delete: if request.auth != null && resource.data.authorUid == request.auth.uid;
    }
  }
}
